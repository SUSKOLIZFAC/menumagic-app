rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        'email' in request.auth.token && (
        request.auth.token.email.lower() == 'ahmedbahloul230@gmail.com' ||
        request.auth.token.email.lower() == 'ali@onemenu.app'
      );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidRestaurant() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.ownerId is string &&
             (!('slug' in data) || (data.slug is string && data.slug.size() <= 150)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 1000));
    }

    function isValidMenu() {
      let data = request.resource.data;
      return data.keys().hasAll(['restaurantId', 'categories', 'updatedAt']) &&
             data.restaurantId is string &&
             data.categories is list && data.categories.size() <= 50;
    }

    function isValidOrder() {
      let data = request.resource.data;
      return data.keys().hasAll(['restaurantId', 'tableNumber', 'items', 'status', 'total', 'createdAt']) &&
             data.restaurantId is string &&
             data.tableNumber is string && data.tableNumber.size() > 0 && data.tableNumber.size() <= 20 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.status in ['pending', 'preparing', 'ready', 'completed', 'cancelled'] &&
             data.total is number && data.total >= 0;
    }

    function isValidLead() {
      let data = request.resource.data;
      return data.keys().hasAll(['restaurantName', 'contactPerson', 'email', 'phone', 'status', 'createdAt']) &&
             data.restaurantName is string && data.restaurantName.size() > 0 && data.restaurantName.size() <= 100 &&
             data.contactPerson is string && data.contactPerson.size() > 0 && data.contactPerson.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50 &&
             data.status in ['new', 'contacted', 'closed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leads/{leadId} {
      allow create: if isValidLead() && request.resource.data.status == 'new';
      allow read, update, delete: if isAdmin(); // Only admins can read/manage leads
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isAdmin() && isValidRestaurant();
      allow update: if isAdmin() && isValidRestaurant() &&
                    request.resource.data.ownerId == resource.data.ownerId; // ownerId is immutable
      allow delete: if isAdmin();
    }

    match /menus/{menuId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMenu();
      allow update: if isAdmin() && isValidMenu() &&
                    request.resource.data.restaurantId == resource.data.restaurantId; // restaurantId is immutable
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidOrder() && request.resource.data.status == 'pending';
      allow update: if isValidOrder() &&
                    request.resource.data.restaurantId == resource.data.restaurantId &&
                    request.resource.data.tableNumber == resource.data.tableNumber &&
                    request.resource.data.total == resource.data.total &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated();
    }
  }
}
